# Java / Maven / IntelliJ .gitignore

# ========================
# Maven build output
# ========================
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# ========================
# IntelliJ IDEA
# ========================
.idea/
*.iws
*.iml
*.ipr
out/
.idea_modules/

# ========================
# Eclipse
# ========================
.classpath
.project
.settings/
bin/

# ========================
# VS Code
# ========================
.vscode/

# ========================
# Test output & reports
# ========================
test-output/
allure-results/
allure-report/
cucumber-reports/
surefire-reports/
*.html
*.xml
!pom.xml

# ========================
# Logs
# ========================
*.log
logs/

# ========================
# Screenshots (generated by tests)
# ========================
screenshots/
*.png
*.jpg

# ========================
# Driver binaries
# ========================
Tools/*.exe
Tools/chromedriver
Tools/geckodriver
drivers/

# ========================
# OS files
# ========================
.DS_Store
Thumbs.db
desktop.ini

# ========================
# Environment / secrets
# ========================
.env
*.properties.local
config.local.properties
